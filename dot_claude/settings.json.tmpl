{
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "{{ if .work }}0{{ else }}1{{ end }}",
    "GIT_PAGER": "cat",
{{- if not .work }}
    "OTEL_EXPORTER_OTLP_ENDPOINT": "https://otlp.nr-data.net:4317",
    "OTEL_EXPORTER_OTLP_HEADERS": "api-key={{ (onepasswordDetailsFields "2pq2wxjeprrzpsblokgtruqkia").hxwmipcw5wvjmvpymoabyrm23q.value }}",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "http/protobuf",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_METRICS_INCLUDE_VERSION": "1",
{{- end }}
    "SHELL": "/opt/homebrew/bin/zsh"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/notification.sh",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '{{ .chezmoi.homeDir }}/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/stop.sh",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(chmod:*)",
      "Bash(cp:*)",
      "Bash(curl:*)",
      "Bash(cursor:*)",
      "Bash(docker logs:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(gh api:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(git add:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)",
      "Bash(git push:*)",
      "Bash(git rm:*)",
      "Bash(git stash:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(open:*)",
      "Bash(rm:*)",
      "Bash(rg:*)",
      "Glob(**)",
      "Grep(**)",
      "LS(**)",
      "Read(~/.zshrc)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~/)",
      "Bash(sudo:*)"
    ]
  },
  "statusLine": {
    "command": "ccusage statusline",
    "type": "command"
  }
}
{{- "" -}}
