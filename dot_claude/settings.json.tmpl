{
  "env": {
    "GIT_PAGER": "cat",
    "SHELL": "/opt/homebrew/bin/zsh"
  },
  "permissions": {
    "allow": [
      "Bash(agent-browser:*)",
      "Bash(cat:*)",
      "Bash(chmod:*)",
      "Bash(cp:*)",
      "Bash(curl:*)",
      "Bash(cursor:*)",
      "Bash(docker logs:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(gh api:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(git add:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)",
      "Bash(git push:*)",
      "Bash(git rm:*)",
      "Bash(git stash:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(open:*)",
      "Bash(rm:*)",
      "Bash(rg:*)",
      "Read(**)",
      "EnterWorktree",
      "ExitWorktree"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~/)",
      "Bash(sudo:*)"
    ],
    "defaultMode": "auto"
  },
  "model": "claude-fable-5[1m]",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash '{{ .chezmoi.homeDir }}/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "wt list statusline --format=claude-code"
  },
  "enabledPlugins": {
    "caveman@caveman": true,
    "skill-creator@claude-plugins-official": true,
    "worktrunk@worktrunk": true,
    "catppuccin@claude-themes": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "cognition": {
      "source": {
        "source": "github",
        "repo": "club-cog/devin-handoff"
      }
    },
    "worktrunk": {
      "source": {
        "source": "github",
        "repo": "max-sixty/worktrunk"
      }
    },
    "claude-themes": {
      "source": {
        "source": "github",
        "repo": "matcra587/claude-themes"
      }
    }
  },
  "language": "日本語",
  "sandbox": {
    "enabled": false,
    "filesystem": {
      "allowWrite": [
        "{{ .chezmoi.homeDir }}/Library/Caches/hk",
        "{{ .chezmoi.homeDir }}/Library/Caches/mise",
        "{{ .chezmoi.homeDir }}/.agent-browser"
      ]
    },
    "excludedCommands": [
      "git push",
      "git push *"
    ]
  },
  "effortLevel": "high",
  "advisorModel": "fable",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "theme": "custom:catppuccin:catppuccin-mocha-ansi",
  "editorMode": "normal"
}
