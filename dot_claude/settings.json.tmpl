{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "advisorModel": "fable",
  "editorMode": "normal",
  "effortLevel": "high",
  "enabledPlugins": {
    "catppuccin@claude-themes": true,
    "caveman@caveman": true,
    "crit@crit": true,
    "i-have-adhd@i-have-adhd": true,
    "skill-creator@claude-plugins-official": true,
    "worktrunk@worktrunk": true
  },
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "GIT_PAGER": "cat",
    "SHELL": "/opt/homebrew/bin/zsh"
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "repo": "JuliusBrussee/caveman",
        "source": "github"
      }
    },
    "claude-themes": {
      "source": {
        "repo": "matcra587/claude-themes",
        "source": "github"
      }
    },
    "cognition": {
      "source": {
        "repo": "club-cog/devin-handoff",
        "source": "github"
      }
    },
    "crit": {
      "source": {
        "repo": "tomasz-tomczyk/crit",
        "source": "github"
      }
    },
    "i-have-adhd": {
      "source": {
        "repo": "ayghri/i-have-adhd",
        "source": "github"
      }
    },
    "worktrunk": {
      "source": {
        "repo": "max-sixty/worktrunk",
        "source": "github"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "sh '{{ .chezmoi.homeDir }}/.claude/hooks/i-have-adhd-activate.sh'",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "command": "bash '{{ .chezmoi.homeDir }}/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "language": "日本語",
  "model": "claude-fable-5[1m]",
  "permissions": {
    "allow": [
      "Bash(agent-browser:*)",
      "Bash(cat:*)",
      "Bash(chmod:*)",
      "Bash(cp:*)",
      "Bash(curl:*)",
      "Bash(cursor:*)",
      "Bash(docker logs:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(gh api:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(git add:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)",
      "Bash(git push:*)",
      "Bash(git rm:*)",
      "Bash(git stash:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(open:*)",
      "Bash(rm:*)",
      "Bash(rg:*)",
      "Read(**)",
      "EnterWorktree",
      "ExitWorktree"
    ],
    "defaultMode": "auto",
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~/)",
      "Bash(sudo:*)"
    ]
  },
  "sandbox": {
    "enabled": false,
    "excludedCommands": [
      "git push",
      "git push *"
    ],
    "filesystem": {
      "allowWrite": [
        "{{ .chezmoi.homeDir }}/Library/Caches/hk",
        "{{ .chezmoi.homeDir }}/Library/Caches/mise",
        "{{ .chezmoi.homeDir }}/.agent-browser"
      ]
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "wt list statusline --format=claude-code",
    "type": "command"
  },
  "theme": "custom:catppuccin:catppuccin-mocha-ansi",
  "tui": "fullscreen"
}