{{- $email := "" -}}
{{- if hasKey . "email" -}}
{{-   $email = .email -}}
{{- else -}}
{{-   $email = promptString "email" -}}
{{- end -}}

{{- $opAccount := "" -}}
{{- if hasKey . "opAccount" -}}
{{-   $opAccount = .opAccount -}}
{{- else -}}
{{-   $opAccount = promptString "opAccount" -}}
{{- end -}}

[data]
    email = {{ $email | quote }}
    opAccount = {{ $opAccount | quote }}
    work = {{ promptBool "work" }}
