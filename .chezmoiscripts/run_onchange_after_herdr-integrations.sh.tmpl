{{- if (eq .chezmoi.os "darwin") -}}
#!/bin/bash

set -eu

# Install herdr agent-state integration hooks for the AI coding agents used
# in this environment. These hooks let each agent report blocked/working/done
# state to herdr instead of relying on output heuristics.
# Reruns when this list changes (e.g. when an agent is added below).
# agents: claude codex omp pi

# Rebuild PATH from scratch: mise env prepends its tool bin dirs, and dropping
# the inherited PATH keeps stale entries (e.g. Homebrew's node) from shadowing them.
export PATH="/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin"
cd "${HOME}"
eval "$(mise env -s bash)"

if ! command -v herdr >/dev/null 2>&1; then
  echo "herdr not found on PATH; run 'mise install' first" >&2
  exit 1
fi

# The Pi and OMP integrations write extensions into these directories and
# require them to exist beforehand (Herdr does not create them).
mkdir -p "${PI_CODING_AGENT_DIR:-${HOME}/.omp/agent}/extensions"
mkdir -p "${PI_CODING_AGENT_DIR:-${HOME}/.pi/agent}/extensions"

for agent in claude codex omp pi; do
  echo "Installing herdr integration: ${agent}"
  herdr integration install "${agent}"
done
{{- end }}
