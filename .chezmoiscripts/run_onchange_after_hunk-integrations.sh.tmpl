{{- if (eq .chezmoi.os "darwin") -}}
#!/bin/bash

set -eu

# Symlink the hunk-review skill bundled with hunk into Claude Code's skills
# directory so agents can drive live hunk review sessions.

# Rebuild PATH from scratch: mise env prepends its tool bin dirs, and dropping
# the inherited PATH keeps stale entries (e.g. Homebrew's node) from shadowing them.
export PATH="/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin"
cd "${HOME}"
eval "$(mise env -s bash)"

if ! command -v hunk >/dev/null 2>&1; then
  echo "hunk not found on PATH; run 'mise install' first" >&2
  exit 1
fi

skill_dir="$(dirname "$(hunk skill path)")"

# hunk reports a version-pinned mise install path; link through mise's
# "latest" alias instead so the skill keeps working after upgrades.
latest_dir="$(echo "${skill_dir}" | sed -E 's|(/installs/hunk/)[^/]+|\1latest|')"
if [ -d "${latest_dir}" ]; then
  skill_dir="${latest_dir}"
fi

mkdir -p "${HOME}/.claude/skills"
ln -sfn "${skill_dir}" "${HOME}/.claude/skills/hunk-review"
echo "Installed hunk-review skill: ${skill_dir}"
{{- end }}
