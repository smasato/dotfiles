{{- if (eq .chezmoi.os "darwin") -}}
#!/bin/bash

set -eu

# Install herdr plugins used in this environment.
# Reruns when this list changes (e.g. when a plugin is added below).
# plugins: devashish2203/herdr-worktrunk smarzban/herdr-file-viewer crokily/herdr-lazygit

# Rebuild PATH from scratch: mise env prepends its tool bin dirs, and dropping
# the inherited PATH keeps stale entries (e.g. Homebrew's node) from shadowing them.
export PATH="/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin"
cd "${HOME}"
eval "$(mise env -s bash)"

if ! command -v herdr >/dev/null 2>&1; then
  echo "herdr not found on PATH; run 'mise install' first" >&2
  exit 1
fi

for plugin in devashish2203/herdr-worktrunk smarzban/herdr-file-viewer crokily/herdr-lazygit; do
  echo "Installing herdr plugin: ${plugin}"
  herdr plugin install "${plugin}" --yes
done
{{- end }}
